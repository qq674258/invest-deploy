# 复制为 .env 供 docker compose 使用

# 基础镜像（任选其一，163 镜像 hub-mirror.c.163.com 已失效勿用）
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12-slim-bookworm
# PYTHON_IMAGE=docker.1ms.run/library/python:3.12-slim-bookworm
# PYTHON_IMAGE=python:3.12-slim-bookworm

# 构建时 pip 源（可选）
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# 容器内访问 Yahoo/FRED（宿主 Clash 在 10808 时；Linux 需 docker-compose 中 extra_hosts）
# 定时采集在 api 容器内运行，此处必须配置，否则仅手动 crawl 容器能翻墙
# HTTP_PROXY=http://host.docker.internal:10808
# HTTPS_PROXY=http://host.docker.internal:10808

# 前台 Web 对外端口（宝塔/防火墙需放行，默认 3009，避免占用 3000）
WEB_HOST_PORT=3009

# API 对外端口（默认 18001，避免与 8000/8001 冲突；容器内仍为 8001）
API_HOST_PORT=18001

FRED_API_KEY=

# 管理后台（api 容器必须能读到，保存基金等操作需鉴权）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
ADMIN_SECRET=

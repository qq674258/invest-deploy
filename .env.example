# 复制为 .env 并填写

DATABASE_URL=sqlite:///./data/invest.db
# 生产: postgresql://user:pass@localhost:5432/invest

FRED_API_KEY=
TUSHARE_TOKEN=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

CRAWL_USER_AGENT=InvestAnalyzer/1.0
# 若 Clash/V2Ray 运行在 10808，可显式指定（与系统代理二选一即可）
# HTTP_PROXY=http://127.0.0.1:10808
LOG_LEVEL=INFO

# 行情历史长度（二选一；默认近 1 年）
OHLCV_LOOKBACK_YEARS=1
# OHLCV_LOOKBACK_DAYS=3800

# 管理后台（请务必修改默认密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
ADMIN_SECRET=

# 邮件告警（SMTP 密码也可在管理后台「告警与定时」填写）
# SMTP_PASSWORD=your-app-password

# 前端
NEXT_PUBLIC_API_URL=http://localhost:18001
